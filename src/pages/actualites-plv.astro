---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import blogCategories from '../data/blog-categories.json';

const allPosts = await getCollection('posts', p => !!p.data.date);
const posts = allPosts.sort((a, b) =>
  new Date(b.data.date!).getTime() - new Date(a.data.date!).getTime()
);

// Filtres = catégories réellement utilisées par au moins un article, dans
// l'ordre du manifeste (slug → label). Un article sans `category` reste
// visible seulement sous "Tous".
const labelBySlug = new Map(blogCategories.map(c => [c.slug, c.label]));
const usedSlugs = new Set(posts.map(p => p.data.category).filter(Boolean));
const filters = blogCategories
  .filter(c => usedSlugs.has(c.slug))
  .map(c => ({ slug: c.slug, label: c.label }));
---

<BaseLayout
  title="Actualités PLV — Conseils et tendances merchandising | KONTFEEL"
  description="Conseils d'experts sur la PLV, le merchandising et la communication en point de vente. Fabricant français depuis 10 ans."
>
  <section class="blog-list">
    <div class="blog-container">

      <header class="blog-header">
        <h1 class="blog-title">Actualités PLV</h1>
        <p class="blog-intro">Conseils terrain, choix techniques et tendances merchandising par les équipes Kontfeel.</p>
      </header>

      {posts.length === 0 ? (
        <p class="blog-empty">Articles à venir.</p>
      ) : (
        <>
          {filters.length > 0 && (
            <nav class="blog-filters" aria-label="Filtrer les articles par catégorie">
              <button type="button" class="blog-filter is-active" data-filter="all">
                Tous
              </button>
              {filters.map(f => (
                <button type="button" class="blog-filter" data-filter={f.slug}>
                  {f.label}
                </button>
              ))}
            </nav>
          )}

          <ul class="blog-grid">
            {posts.map(post => {
              const date = new Date(post.data.date!).toLocaleDateString('fr-FR', {
                year: 'numeric', month: 'long', day: 'numeric'
              });
              const category = post.data.category ?? '';
              const catLabel = category ? labelBySlug.get(category) : undefined;
              return (
                <li class="blog-card" data-category={category}>
                  {post.data.image && (
                    <a href={`/actualites-plv/${post.id}/`}>
                      <img
                        src={post.data.image}
                        alt={post.data.imageAlt ?? post.data.title}
                        class="blog-card-img"
                        loading="lazy"
                      />
                    </a>
                  )}
                  <div class="blog-card-body">
                    {catLabel && (
                      <div class="blog-card-tags">
                        <span class="blog-card-tag">{catLabel}</span>
                      </div>
                    )}
                    <h2 class="blog-card-title">
                      <a href={`/actualites-plv/${post.id}/`}>{post.data.title}</a>
                    </h2>
                    {post.data.description && (
                      <p class="blog-card-desc">{post.data.description}</p>
                    )}
                    <div class="blog-card-meta">
                      <time datetime={post.data.date}>{date}</time>
                      <span>·</span>
                      <span>{post.data.author}</span>
                    </div>
                  </div>
                </li>
              );
            })}
          </ul>

          <p class="blog-empty-filter is-hidden" data-empty-filter>
            Aucun article dans cette catégorie pour le moment.
          </p>
        </>
      )}

    </div>
  </section>
</BaseLayout>

<style>
  .blog-list {
    padding: 64px 0 96px;
  }
  .blog-container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 24px;
  }
  .blog-header {
    margin-bottom: 48px;
  }
  .blog-title {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 700;
    color: var(--dark);
    margin-bottom: 12px;
  }
  .blog-intro {
    font-size: 17px;
    color: var(--gray-600);
    line-height: 1.6;
  }
  .blog-empty {
    color: var(--gray-500);
    font-size: 16px;
  }

  /* ═══ Filtres catégorie (vanilla, scroll horizontal mobile) ═══ */
  .blog-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 32px;
  }
  @media (max-width: 600px) {
    .blog-filters {
      flex-wrap: nowrap;
      overflow-x: auto;
      padding-bottom: 6px;
      margin-left: -24px;
      margin-right: -24px;
      padding-left: 24px;
      padding-right: 24px;
      scrollbar-width: thin;
    }
    .blog-filter { flex-shrink: 0; }
  }
  .blog-filter {
    appearance: none;
    border: 1.5px solid var(--gray-100, #e5e7eb);
    background: #fff;
    color: var(--dark, #1a1a2e);
    font: inherit;
    font-size: 14px;
    font-weight: 500;
    padding: 8px 18px;
    border-radius: 99px;
    cursor: pointer;
    transition: border-color .15s, background .15s, color .15s;
  }
  .blog-filter:hover { border-color: var(--rose, #E8336D); color: var(--rose, #E8336D); }
  .blog-filter.is-active {
    background: var(--rose, #E8336D);
    border-color: var(--rose, #E8336D);
    color: #fff;
  }

  .blog-empty-filter {
    color: var(--gray-500, #6b7280);
    font-size: 15px;
    text-align: center;
    padding: 48px 0;
  }
  .blog-empty-filter.is-hidden { display: none; }
  .blog-card.is-hidden { display: none; }

  .blog-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 32px;
  }
  .blog-card {
    background: white;
    border: 1px solid var(--gray-100);
    border-radius: var(--radius);
    overflow: hidden;
    transition: box-shadow 0.2s;
  }
  .blog-card:hover { box-shadow: 0 4px 24px rgba(0,0,0,0.08); }
  .blog-card-img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
  }
  .blog-card-body {
    padding: 20px 24px 24px;
  }
  .blog-card-tags {
    display: flex;
    gap: 6px;
    margin-bottom: 10px;
  }
  .blog-card-tag {
    font-size: 11px;
    font-weight: 600;
    color: var(--rose);
    background: var(--rose-light);
    padding: 3px 8px;
    border-radius: 99px;
  }
  .blog-card-title {
    font-size: 17px;
    font-weight: 700;
    line-height: 1.35;
    margin-bottom: 10px;
  }
  .blog-card-title a {
    color: var(--dark);
    text-decoration: none;
  }
  .blog-card-title a:hover { color: var(--rose); }
  .blog-card-desc {
    font-size: 14px;
    line-height: 1.6;
    color: var(--gray-600);
    margin-bottom: 16px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: var(--gray-500);
  }
</style>

<script is:inline>
  // Filtre client par catégorie (montre/cache les cartes selon data-category)
  ;(function () {
    const filters = document.querySelectorAll('.blog-filter')
    const cards   = document.querySelectorAll('.blog-card[data-category]')
    const empty   = document.querySelector('[data-empty-filter]')
    if (!filters.length || !cards.length) return

    function apply(value) {
      let visible = 0
      cards.forEach((card) => {
        const ok = value === 'all' || card.dataset.category === value
        card.classList.toggle('is-hidden', !ok)
        if (ok) visible++
      })
      if (empty) empty.classList.toggle('is-hidden', visible > 0)
    }

    filters.forEach((btn) => {
      btn.addEventListener('click', () => {
        filters.forEach((b) => b.classList.toggle('is-active', b === btn))
        apply(btn.dataset.filter)
      })
    })
  })()
</script>
