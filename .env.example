# ──────────────────────────────────────────────────────────
# Variables d'environnement Astro — copiez ce fichier en .env
# et remplissez les valeurs.
# ──────────────────────────────────────────────────────────

# URL de l'endpoint PHP qui reçoit les demandes de devis (POST JSON)
# Payload envoyé : { nom, societe, telephone, email, quantite, message, source, sentAt }
PUBLIC_DEVIS_ENDPOINT=https://votre-outil.example.com/api/devis

# ──────────────────────────────────────────────────────────
# Stripe (mode Test puis Live)
# Récupérer les clés dans : Stripe Dashboard → Developers → API keys
# ⚠️ STRIPE_SECRET_KEY ne doit JAMAIS être exposée côté client.
# ──────────────────────────────────────────────────────────
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxx

# URL publique du site, utilisée pour les redirections success/cancel Stripe
PUBLIC_SITE_URL=http://localhost:4321
