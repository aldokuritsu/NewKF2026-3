---
/**
 * TextEditorialBlock — Section éditoriale (texte expert, à propos…)
 * Rendu markdown → HTML via marked (format natif Sveltia CMS).
 */
import { marked } from 'marked'

interface Props {
  block: {
    heading?: string
    content?: string
  }
}

const { block } = Astro.props
const html = block.content ? marked.parse(block.content, { async: false }) as string : ''
---

<section class="te-block" id="expert">
  <div class="te-inner">

    {block.heading && (
      <header class="te-header">
        <span class="te-eyebrow" aria-hidden="true"></span>
        <h2 class="te-heading">{block.heading}</h2>
      </header>
    )}

    {html && <div class="te-body prose" set:html={html} />}

  </div>
</section>

<style>
  .te-block { background: #f8f9fb; padding: 72px 24px; margin: 0; }
  .te-inner { max-width: 820px; margin: 0 auto; }

  .te-header { display: flex; align-items: center; gap: 20px; margin-bottom: 32px; }
  .te-eyebrow {
    display: block; flex-shrink: 0; width: 4px; height: 48px;
    background: linear-gradient(180deg, var(--rose, #E8336D) 0%, #D0356A 100%);
    border-radius: 4px;
  }
  .te-heading {
    font-size: clamp(22px, 3vw, 28px); font-weight: 700;
    color: var(--dark, #1a1a2e); line-height: 1.25; margin: 0;
  }

  .te-body { color: var(--gray-700, #374151); line-height: 1.85; font-size: 16px; }

  :global(.te-body p)        { margin: 0 0 20px; }
  :global(.te-body p:last-child) { margin-bottom: 0; }
  :global(.te-body h2) { font-size: 22px; font-weight: 700; color: var(--dark, #1a1a2e); margin: 40px 0 14px; }
  :global(.te-body h3) {
    font-size: 15px; font-weight: 800; text-transform: uppercase;
    letter-spacing: .07em; color: var(--dark, #1a1a2e); margin: 28px 0 10px;
  }
  :global(.te-body strong) { font-weight: 600; color: var(--dark, #1a1a2e); }
  :global(.te-body ul, .te-body ol) { margin: 0 0 20px 24px; }
  :global(.te-body li) { margin-bottom: 8px; }
  :global(.te-body blockquote) {
    border-left: 4px solid var(--rose, #E8336D); margin: 32px 0;
    padding: 16px 24px; background: rgba(232, 51, 109, .05);
    border-radius: 0 8px 8px 0; font-style: italic; color: var(--gray-500, #6b7280);
  }
  :global(.te-body a)       { color: var(--rose, #E8336D); text-decoration: underline; }
  :global(.te-body a:hover) { color: var(--rose-dark, #C02259); }
  :global(.te-body code)    { background: #f1f5f9; padding: 2px 6px; border-radius: 4px; font-size: .9em; }
  :global(.te-body pre)     {
    background: #1e293b; color: #e2e8f0; padding: 20px 24px;
    border-radius: 8px; overflow-x: auto; font-size: 14px; margin: 24px 0;
  }
</style>
