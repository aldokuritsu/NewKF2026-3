---
/**
 * SubNav — Barre d'ancres sticky qui apparaît au scroll (>300px)
 * juste sous la navbar, avec scrollspy + bouton retour en haut.
 *
 * Inspiré du prototype `prototype/index.html` (.sub-nav).
 *
 * Props :
 *   entries : { anchor: string; label: string }[]
 *
 * Si `entries.length < 2`, le composant ne rend rien (pas d'intérêt).
 */
import type { SubNavEntry } from '../lib/blockNav'

interface Props {
  entries: SubNavEntry[]
}

const { entries } = Astro.props
const enabled = entries.length >= 2
---

{enabled && (
  <div class="sub-nav" id="subNav" aria-label="Navigation dans la page">
    <div class="sub-nav-inner">
      <nav class="sub-nav-links">
        {entries.map(e => (
          <a href={`#${e.anchor}`} data-anchor={e.anchor}>{e.label}</a>
        ))}
      </nav>
      <a href="#" class="sub-nav-top" title="Remonter en haut" aria-label="Remonter en haut">↑</a>
    </div>
  </div>
)}

<script>
  (() => {
    const subNav = document.getElementById('subNav')
    if (!subNav) return

    const links = Array.from(subNav.querySelectorAll<HTMLAnchorElement>('.sub-nav-links a'))
    const anchors = links.map(a => a.dataset.anchor!).filter(Boolean)
    const sections = anchors
      .map(id => document.getElementById(id))
      .filter((el): el is HTMLElement => el !== null)

    const topBtn = subNav.querySelector<HTMLAnchorElement>('.sub-nav-top')
    topBtn?.addEventListener('click', (ev) => {
      ev.preventDefault()
      window.scrollTo({ top: 0, behavior: 'smooth' })
    })

    let ticking = false
    const onScroll = () => {
      if (ticking) return
      ticking = true
      requestAnimationFrame(() => {
        // Visibilité : apparaît après 300px
        subNav.classList.toggle('is-visible', window.scrollY > 300)

        // Scrollspy : section dont le top est passé sous 150px
        let current = ''
        for (const section of sections) {
          if (window.scrollY >= section.offsetTop - 150) current = section.id
        }
        for (const link of links) {
          link.classList.toggle('is-active', link.dataset.anchor === current)
        }
        ticking = false
      })
    }

    window.addEventListener('scroll', onScroll, { passive: true })
    onScroll()
  })()
</script>

<style>
  html { scroll-behavior: smooth; }

  .sub-nav {
    position: fixed;
    top: 72px; /* hauteur de .navbar-inner */
    left: 0;
    width: 100%;
    background: var(--dark);
    color: var(--white);
    z-index: 90;
    transform: translateY(-100%);
    opacity: 0;
    visibility: hidden;
    transition: transform .3s ease, opacity .3s ease, visibility .3s ease;
    box-shadow: 0 4px 12px rgba(0, 0, 0, .15);
    border-top: 1px solid rgba(255, 255, 255, .1);
  }

  .sub-nav.is-visible {
    transform: translateY(0);
    opacity: 1;
    visibility: visible;
  }

  .sub-nav-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 10px 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }

  .sub-nav-links {
    display: flex;
    gap: 24px;
    align-items: center;
    min-width: 0;
  }

  .sub-nav-links a {
    color: var(--gray-300);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    line-height: 1;
    padding: 6px 0;
    transition: color .2s;
    white-space: nowrap;
  }

  .sub-nav-links a:hover { color: var(--rose); }

  .sub-nav-links a.is-active {
    color: var(--white);
    font-weight: 600;
  }

  .sub-nav-top {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    background: rgba(255, 255, 255, .1);
    color: var(--white);
    border-radius: 6px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    font-weight: 700;
    transition: background .2s;
  }

  .sub-nav-top:hover { background: var(--rose); }

  @media (max-width: 768px) {
    .sub-nav-inner { padding: 8px 16px; gap: 12px; }
    .sub-nav-links {
      gap: 16px;
      overflow-x: auto;
      white-space: nowrap;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .sub-nav-links::-webkit-scrollbar { display: none; }
  }
</style>
