---
/**
 * Navbar — En-tête principal sur 2 lignes (toutes les pages).
 *
 * Ligne 1 (marque) : logo · recherche (placeholder) · liens utilitaires
 *                     (Réalisations, Blog, Contact, téléphone) · panier (placeholder).
 * Ligne 2 (nav)    : les rubriques, chacune avec son mega-menu (3 niveaux).
 *
 * - Seule la rubrique courante ouvre son tiroir (mega desktop / accordéon mobile).
 * - Sur la home (showAllMegaMenus=true), toutes les rubriques ouvrent leur tiroir.
 * - Triggers du tiroir : hover, clic, clavier (Enter/Space toggle, Escape ferme).
 *
 * ⚠️ Recherche et panier sont des PLACEHOLDERS visuels non fonctionnels
 *    (site statique — câblage ultérieur).
 *
 * Props :
 *   currentSiloSlug?   : string  — slug de la rubrique courante
 *   currentPath?       : string  — chemin URL pour marquer l'élément actif
 *   showAllMegaMenus?  : boolean — déploie toutes les rubriques (home)
 */
import { silos } from '../data/silos'

interface Props {
  currentSiloSlug?: string
  currentPath?: string
  showAllMegaMenus?: boolean
}

const { currentSiloSlug, currentPath = '', showAllMegaMenus = false } = Astro.props
---

<header class="navbar" id="navbar">

  <!-- ═══ Ligne 1 : marque · recherche · utilitaires · panier ═══ -->
  <div class="header-top">
    <div class="header-top-inner">

      <a href="/" class="logo" aria-label="KONTFEEL — Accueil">
        <img src="/assets/images/logo.svg" alt="KONTFEEL" width="160" height="48" />
      </a>

      <!-- Recherche — PLACEHOLDER visuel (non fonctionnel) -->
      <form class="search" role="search" aria-label="Recherche produit (bientôt disponible)" onsubmit="return false;">
        <input
          type="search"
          class="search-input"
          placeholder="Trouver un produit"
          aria-label="Trouver un produit"
          autocomplete="off"
        />
        <button type="button" class="search-btn" aria-label="Rechercher" tabindex="-1">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/>
            <path d="M20 20l-3.5-3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
      </form>

      <nav class="header-utils" aria-label="Liens utiles">
        <a href="/realisations-plv/" class="util-link">Réalisations</a>
        <a href="/actualites-plv/" class="util-link">Blog</a>
        <a href="/contact/" class="util-link">Contact</a>
        <a href="tel:0278775393" class="util-phone">02&nbsp;78&nbsp;77&nbsp;53&nbsp;93</a>
      </nav>

      <!-- Panier — PLACEHOLDER (non fonctionnel) -->
      <div class="cart" role="img" aria-label="Panier — bientôt disponible (0 article, 0,00 €)" title="Panier — bientôt disponible">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M3 4h2l2.4 12.3a1 1 0 0 0 1 .8h9.2a1 1 0 0 0 1-.8L21 8H6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="10" cy="20" r="1.4" fill="currentColor"/>
          <circle cx="18" cy="20" r="1.4" fill="currentColor"/>
        </svg>
        <span class="cart-badge" aria-hidden="true">0</span>
        <span class="cart-total">0,00&nbsp;€</span>
      </div>

      <button class="hamburger" id="hamburger" type="button" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="mobile-menu">
        <span></span><span></span><span></span>
      </button>

    </div>
  </div>

  <!-- ═══ Ligne 2 : rubriques (mega-menu) ═══ -->
  <div class="header-nav">
    <nav class="nav-links" aria-label="Navigation principale">
      {silos.map(silo => {
        const isCurrent = silo.slug === currentSiloSlug
        const showMega = showAllMegaMenus || isCurrent
        const panelId = `mega-${silo.slug}`

        if (!showMega) {
          return (
            <a href={silo.href} class="nav-link">{silo.label}</a>
          )
        }

        return (
          <div class="nav-item nav-item--mega" data-mega-item>
            <button
              type="button"
              class:list={['nav-link', 'nav-trigger', { 'is-active': isCurrent }]}
              aria-haspopup="true"
              aria-expanded="false"
              aria-controls={panelId}
            >
              {silo.label}
              <svg class="caret" width="10" height="10" viewBox="0 0 12 12" aria-hidden="true">
                <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>

            <div
              class="mega-panel"
              id={panelId}
              role="menu"
              aria-hidden="true"
            >
              <a href={silo.href} class:list={['mega-pillar', { active: currentPath === silo.href }]} role="menuitem">
                Voir tout : {silo.label} <span aria-hidden="true">→</span>
              </a>
              <div class="mega-grid">
                {silo.children?.map(cat => (
                  <div class="mega-col">
                    <a
                      href={cat.href}
                      role="menuitem"
                      class:list={['mega-cat', { active: currentPath === cat.href, 'has-sub': !!cat.children?.length }]}
                    >
                      {cat.label}
                    </a>
                    {cat.children?.length ? (
                      <div class="mega-sublist">
                        {cat.children.map(sub => (
                          <a
                            href={sub.href}
                            role="menuitem"
                            class:list={['mega-sublink', { active: currentPath === sub.href }]}
                          >
                            {sub.label}
                          </a>
                        ))}
                      </div>
                    ) : null}
                  </div>
                ))}
              </div>
            </div>
          </div>
        )
      })}
    </nav>
  </div>

  <!-- ═══ Menu mobile ═══ -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <nav aria-label="Navigation mobile">

      <!-- Recherche mobile — PLACEHOLDER visuel -->
      <form class="mobile-search" role="search" aria-label="Recherche produit (bientôt disponible)" onsubmit="return false;">
        <input type="search" placeholder="Trouver un produit" aria-label="Trouver un produit" autocomplete="off" />
      </form>

      {silos.map(silo => {
        const isCurrent = silo.slug === currentSiloSlug
        const showMega = showAllMegaMenus || isCurrent

        if (!showMega) {
          return <a href={silo.href} class="mobile-link">{silo.label}</a>
        }

        return (
          <details class:list={['mobile-group', { 'is-current': isCurrent }]} open={isCurrent}>
            <summary class="mobile-summary">
              <span>{silo.label}</span>
              <svg class="mobile-caret" width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
                <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </summary>
            <div class="mobile-children">
              <a
                href={silo.href}
                class:list={['mobile-link', 'mobile-pillar-link', { active: currentPath === silo.href }]}
              >
                Voir tout : {silo.label} <span aria-hidden="true">→</span>
              </a>

              {silo.children?.map(cat => (
                cat.children?.length ? (
                  <details class="mobile-subgroup">
                    <summary class="mobile-subsummary">
                      <span>{cat.label}</span>
                      <svg class="mobile-caret" width="11" height="11" viewBox="0 0 12 12" aria-hidden="true">
                        <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </summary>
                    <div class="mobile-subchildren">
                      <a
                        href={cat.href}
                        class:list={['mobile-link', 'mobile-cat-link', { active: currentPath === cat.href }]}
                      >
                        Voir tout : {cat.label} <span aria-hidden="true">→</span>
                      </a>
                      {cat.children.map(sub => (
                        <a
                          href={sub.href}
                          class:list={['mobile-link', 'mobile-child', { active: currentPath === sub.href }]}
                        >
                          {sub.label}
                        </a>
                      ))}
                    </div>
                  </details>
                ) : (
                  <a
                    href={cat.href}
                    class:list={['mobile-link', 'mobile-child', { active: currentPath === cat.href }]}
                  >
                    {cat.label}
                  </a>
                )
              ))}
            </div>
          </details>
        )
      })}

      <!-- Liens utilitaires (mobile) -->
      <div class="mobile-utils">
        <a href="/realisations-plv/" class="mobile-link">Réalisations</a>
        <a href="/actualites-plv/" class="mobile-link">Blog</a>
        <a href="/contact/" class="mobile-link">Contact</a>
        <a href="tel:0278775393" class="mobile-link">02 78 77 53 93</a>
      </div>

      <a href="/devis/" class="mobile-cta">Devis gratuit →</a>
    </nav>
  </div>
</header>

<script>
// ── Mega-menu : hover + clic + clavier ──────────────────────────────────────
const items = document.querySelectorAll<HTMLElement>('[data-mega-item]')

for (const item of Array.from(items)) {
  const trigger = item.querySelector<HTMLButtonElement>('.nav-trigger')
  const panel   = item.querySelector<HTMLElement>('.mega-panel')
  if (!trigger || !panel) continue

  let closeTimer: number | undefined

  const adjustAlignment = () => {
    // Clamp dans le viewport : le panneau s'ancre sous le trigger (left:0
    // relatif à l'item) puis est décalé juste ce qu'il faut pour rester
    // entre les deux marges, sans jamais déborder à gauche NI à droite.
    const margin = 16
    panel.style.left = '0px'
    const itemLeft   = item.getBoundingClientRect().left
    const panelWidth = panel.offsetWidth
    const maxLeft    = window.innerWidth - margin - panelWidth
    // Position viewport souhaitée = sous l'item ; bornée à [margin, maxLeft].
    const clampedLeft = Math.max(margin, Math.min(itemLeft, maxLeft))
    panel.style.left = `${Math.round(clampedLeft - itemLeft)}px`
  }

  const open = () => {
    window.clearTimeout(closeTimer)
    trigger.setAttribute('aria-expanded', 'true')
    panel.setAttribute('aria-hidden', 'false')
    item.classList.add('is-open')
    requestAnimationFrame(adjustAlignment)
  }

  const close = () => {
    trigger.setAttribute('aria-expanded', 'false')
    panel.setAttribute('aria-hidden', 'true')
    item.classList.remove('is-open')
  }

  const scheduleClose = () => {
    window.clearTimeout(closeTimer)
    closeTimer = window.setTimeout(close, 150)
  }

  // Hover (desktop)
  item.addEventListener('mouseenter', open)
  item.addEventListener('mouseleave', scheduleClose)

  // Clic — toggle, et empêche la fermeture immédiate par mouseleave
  trigger.addEventListener('click', (ev) => {
    ev.preventDefault()
    const isOpen = trigger.getAttribute('aria-expanded') === 'true'
    if (isOpen) close()
    else open()
  })

  // Clavier — Enter / Space ouvrent et focusent le 1er lien ; Escape ferme
  trigger.addEventListener('keydown', (ev) => {
    if (ev.key === 'Enter' || ev.key === ' ') {
      ev.preventDefault()
      open()
      panel.querySelector<HTMLAnchorElement>('a')?.focus()
    } else if (ev.key === 'Escape') {
      close()
    } else if (ev.key === 'ArrowDown') {
      ev.preventDefault()
      open()
      panel.querySelector<HTMLAnchorElement>('a')?.focus()
    }
  })

  panel.addEventListener('keydown', (ev) => {
    if (ev.key === 'Escape') {
      close()
      trigger.focus()
    }
  })

  // Clic en dehors → ferme
  document.addEventListener('click', (ev) => {
    if (!item.contains(ev.target as Node)) close()
  })
}

// ── Hamburger (mobile) ──────────────────────────────────────────────────────
const hamburger  = document.getElementById('hamburger')
const mobileMenu = document.getElementById('mobile-menu')

if (hamburger && mobileMenu) {
  hamburger.addEventListener('click', () => {
    const isOpen = hamburger.getAttribute('aria-expanded') === 'true'
    hamburger.setAttribute('aria-expanded', String(!isOpen))
    mobileMenu.setAttribute('aria-hidden', String(isOpen))
    hamburger.classList.toggle('is-open', !isOpen)
    mobileMenu.classList.toggle('is-open', !isOpen)
  })
}
</script>

<style>
  .navbar {
    background: var(--white);
    border-bottom: 1px solid var(--gray-100);
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
  }

  /* ══ Ligne 1 : marque ══ */
  .header-top { border-bottom: 1px solid var(--gray-100); }

  .header-top-inner {
    max-width: var(--header-max-w);
    margin: 0 auto;
    padding: 0 24px;
    height: 72px;
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .logo { flex-shrink: 0; display: flex; align-items: center; }
  .logo img { height: 42px; width: auto; display: block; }

  /* ── Recherche (placeholder) ── */
  .search {
    flex: 1 1 auto;
    max-width: 440px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    background: var(--gray-50);
    border: 1px solid var(--gray-100);
    border-radius: 99px;
    padding: 0 6px 0 18px;
    height: 42px;
    transition: border-color .15s, background .15s;
  }

  .search:focus-within { border-color: var(--rose); background: var(--white); }

  .search-input {
    flex: 1;
    border: none;
    background: none;
    outline: none;
    font-size: 14px;
    font-family: inherit;
    color: var(--gray-900);
    min-width: 0;
  }

  .search-input::placeholder { color: var(--gray-500); }

  .search-btn {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: none;
    border-radius: 50%;
    background: none;
    color: var(--rose);
    cursor: pointer;
  }

  /* ── Liens utilitaires ── */
  .header-utils {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 22px;
  }

  .util-link,
  .util-phone {
    font-size: 14px;
    color: var(--gray-700);
    text-decoration: none;
    transition: color .15s;
    white-space: nowrap;
  }

  .util-link:hover { color: var(--rose); }

  .util-phone {
    font-weight: 700;
    color: var(--dark);
    letter-spacing: .01em;
  }

  .util-phone:hover { color: var(--rose); }

  /* ── Panier (placeholder) ── */
  .cart {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: var(--rose);
    color: var(--white);
    border-radius: 99px;
    font-size: 14px;
    font-weight: 600;
    cursor: default;
    user-select: none;
    position: relative;
  }

  .cart-badge {
    position: absolute;
    top: -4px;
    left: 8px;
    min-width: 16px;
    height: 16px;
    padding: 0 4px;
    background: var(--white);
    color: var(--rose);
    border-radius: 99px;
    font-size: 11px;
    font-weight: 700;
    line-height: 16px;
    text-align: center;
  }

  .cart-total { white-space: nowrap; }

  /* ══ Ligne 2 : rubriques ══ */
  .header-nav { background: var(--white); }

  .nav-links {
    max-width: var(--header-max-w);
    margin: 0 auto;
    padding: 0 16px;
    min-height: 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 4px;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 500;
    color: var(--gray-700);
    text-decoration: none;
    padding: 8px 10px;
    border-radius: var(--radius-sm);
    transition: color .15s, background .15s;
    white-space: nowrap;
    letter-spacing: .01em;
    line-height: 1.15;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
  }

  .nav-link:hover { color: var(--rose); background: var(--rose-light); }

  .nav-link.is-active {
    color: var(--rose);
    font-weight: 600;
    background: var(--rose-light);
  }

  /* ── Item avec mega-menu ── */
  .nav-item--mega { position: relative; }

  .caret { transition: transform .2s; flex-shrink: 0; }
  .nav-item--mega.is-open .caret { transform: rotate(180deg); }

  /* ── Panneau mega-menu ── */
  .mega-panel {
    position: absolute;
    top: calc(100% + 10px);
    left: 0;
    width: max-content;
    min-width: 760px;
    max-width: min(1080px, 94vw);
    max-height: min(72vh, 640px);
    overflow-y: auto;
    background: var(--white);
    border: 1px solid var(--gray-100);
    border-radius: var(--radius);
    box-shadow: 0 12px 32px rgba(0, 0, 0, .12);
    padding: 16px;
    z-index: 200;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: opacity .15s, transform .15s, visibility .15s;
  }

  .nav-item--mega.is-open .mega-panel {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .mega-pillar {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 600;
    color: var(--rose);
    text-decoration: none;
    padding: 8px 12px;
    margin: 0 0 12px;
    border-radius: var(--radius-sm);
    background: var(--rose-light);
    transition: background .15s;
  }

  .mega-pillar:hover { background: rgba(232, 70, 124, .14); }

  /* Flux multi-colonnes : chaque catégorie (+ ses sous-liens) ne se coupe pas */
  .mega-grid {
    columns: 4 220px;
    column-gap: 20px;
  }

  .mega-col {
    break-inside: avoid;
    margin-bottom: 14px;
  }

  .mega-cat {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: var(--dark);
    text-decoration: none;
    padding: 6px 10px;
    border-radius: var(--radius-sm);
    transition: color .15s, background .15s;
  }

  .mega-cat:hover { color: var(--rose); background: var(--rose-light); }
  .mega-cat.active { color: var(--rose); background: var(--rose-light); }

  .mega-sublist {
    display: flex;
    flex-direction: column;
    margin: 2px 0 0;
    padding-left: 10px;
    border-left: 2px solid var(--gray-100);
    margin-left: 10px;
  }

  .mega-sublink {
    font-size: 12.5px;
    font-weight: 500;
    color: var(--gray-700);
    text-decoration: none;
    padding: 5px 10px;
    border-radius: var(--radius-sm);
    transition: color .15s, background .15s;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .mega-sublink:hover { color: var(--rose); background: var(--rose-light); }
  .mega-sublink.active { color: var(--rose); font-weight: 600; background: var(--rose-light); }

  /* ── Hamburger ── */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    border-radius: var(--radius-sm);
    transition: background .15s;
    flex-shrink: 0;
  }

  .hamburger:hover { background: var(--gray-50); }

  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--dark);
    border-radius: 2px;
    transition: transform .25s, opacity .25s;
  }

  .hamburger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.is-open span:nth-child(2) { opacity: 0; }
  .hamburger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ── Menu mobile ── */
  .mobile-menu {
    display: none;
    overflow: hidden;
    max-height: 0;
    transition: max-height .3s ease;
    border-top: 1px solid var(--gray-100);
    background: var(--white);
  }

  .mobile-menu.is-open { max-height: calc(100vh - 72px); overflow-y: auto; }

  .mobile-menu nav {
    max-width: var(--header-max-w);
    margin: 0 auto;
    padding: 16px 24px 20px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .mobile-search {
    display: flex;
    align-items: center;
    background: var(--gray-50);
    border: 1px solid var(--gray-100);
    border-radius: 99px;
    padding: 0 18px;
    height: 44px;
    margin-bottom: 10px;
  }

  .mobile-search input {
    flex: 1;
    border: none;
    background: none;
    outline: none;
    font-size: 15px;
    font-family: inherit;
    color: var(--gray-900);
    min-width: 0;
  }

  .mobile-search input::placeholder { color: var(--gray-500); }

  .mobile-link {
    font-size: 15px;
    font-weight: 500;
    color: var(--gray-700);
    text-decoration: none;
    padding: 10px 12px;
    border-radius: var(--radius-sm);
    transition: color .15s, background .15s;
  }

  .mobile-link:hover,
  .mobile-link.active { color: var(--rose); background: var(--rose-light); }

  /* ── Accordéon mobile (un par rubrique) ── */
  .mobile-group {
    border-radius: var(--radius-sm);
  }

  .mobile-group + .mobile-group {
    border-top: 1px solid var(--gray-100);
  }

  .mobile-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 14px 12px;
    font-size: 15px;
    font-weight: 600;
    color: var(--dark);
    cursor: pointer;
    list-style: none;
    user-select: none;
    border-radius: var(--radius-sm);
    transition: background .15s, color .15s;
  }

  .mobile-summary::-webkit-details-marker { display: none; }
  .mobile-summary:hover { background: var(--gray-50); }

  .mobile-group.is-current > .mobile-summary {
    color: var(--rose);
    background: var(--rose-light);
  }

  .mobile-caret {
    flex-shrink: 0;
    color: var(--gray-700);
    transition: transform .2s;
  }

  .mobile-group[open] > .mobile-summary .mobile-caret { transform: rotate(180deg); }

  .mobile-children {
    display: flex;
    flex-direction: column;
    gap: 1px;
    padding: 4px 0 12px 12px;
    border-left: 2px solid var(--gray-100);
    margin: 0 0 4px 16px;
  }

  .mobile-pillar-link {
    font-size: 13px;
    font-weight: 600;
    color: var(--rose);
    background: var(--rose-light);
    padding: 8px 12px;
