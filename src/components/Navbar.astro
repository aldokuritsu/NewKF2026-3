---
/**
 * Navbar — En-tête principal sur 2 lignes (toutes les pages).
 *
 * Ligne 1 (marque) : logo · recherche (fonctionnelle, index statique) · liens
 *                     utilitaires (intégrés au bandeau foncé) · téléphone · panier.
 * Ligne 2 (nav)    : les 7 rubriques, chacune avec son mega-menu.
 *
 * Deux modes de rendu du mega-menu :
 *   1. Default (auto-généré) : arbre depuis `src/data/silos.ts`, panneau en flow
 *      multi-colonnes, largeur clampée au viewport (`adjustAlignment`).
 *   2. Custom (`src/data/mega-menus.ts`) : si la rubrique a une entrée dans
 *      `customMegaMenus`, le panneau bascule sur une grille pleine largeur
 *      (calée sur `.nav-links`) avec colonnes éditoriales (titre + image
 *      d'en-tête optionnelle + sous-liens) et un slot promo optionnel.
 *      Layouts : `fixed4` / `grid-3x2` / `auto`. CTA d'en-tête via `pillarCta`.
 *
 * - Seule la rubrique courante ouvre son tiroir (mega desktop / accordéon mobile).
 * - Sur la home (showAllMegaMenus=true), toutes les rubriques ouvrent leur tiroir.
 * - Triggers du tiroir : hover, clic, clavier (Enter/Space toggle, Escape ferme).
 *
 * Props :
 *   currentSiloSlug?   : string  — slug de la rubrique courante
 *   currentPath?       : string  — chemin URL pour marquer l'élément actif
 *   showAllMegaMenus?  : boolean — déploie toutes les rubriques (home)
 */
import { silos } from '../data/silos'
import { getCustomMega } from '../data/mega-menus'

interface Props {
  currentSiloSlug?: string
  currentPath?: string
  showAllMegaMenus?: boolean
}

const { currentSiloSlug, currentPath = '', showAllMegaMenus = false } = Astro.props
---

<header class="navbar" id="navbar">

  <!-- ═══ Bandeau utilitaire foncé (NON sticky — défile au scroll) ═══ -->
  <div class="topbar">
    <div class="topbar-inner">
      <nav class="topbar-links" aria-label="Liens utiles">
        <a href="/realisations-plv/">Réalisations</a>
        <a href="/actualites-plv/">Blog</a>
        <a href="/contact/">Contact</a>
      </nav>
      <p class="topbar-delivery">
        <span class="flag" aria-hidden="true">
          <svg width="18" height="12" viewBox="0 0 18 12">
            <rect width="6" height="12" fill="#0055A4"/>
            <rect x="6" width="6" height="12" fill="#FFFFFF"/>
            <rect x="12" width="6" height="12" fill="#EF4135"/>
          </svg>
        </span>
        Livraison partout en France
      </p>
    </div>
  </div>

  <!-- ═══ Ligne marque (STICKY) : logo · recherche · panier ═══ -->
  <div class="header-top">
    <div class="header-top-inner">

      <a href="/" class="logo" aria-label="KONTFEEL — Accueil">
        <img src="/assets/images/logo.svg" alt="KONTFEEL" width="160" height="48" />
      </a>

      <!-- Hamburger (mobile uniquement, caché en desktop via CSS).
           Placé juste après le logo pour qu'il s'y colle naturellement quand
           la recherche/téléphone/panier disparaissent au breakpoint mobile. -->
      <button class="hamburger" id="hamburger" type="button" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="mobile-menu">
        <span></span><span></span><span></span>
      </button>

      <!-- Recherche (index statique + matcher client) -->
      <form class="search" role="search" aria-label="Recherche sur le site" onsubmit="return false;">
        <input
          type="search"
          id="site-search"
          class="search-input"
          placeholder="Trouver un produit"
          aria-label="Trouver un produit"
          autocomplete="off"
          role="combobox"
          aria-expanded="false"
          aria-controls="search-results"
          aria-autocomplete="list"
        />
        <button type="button" class="search-btn" aria-label="Rechercher" tabindex="-1">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/>
            <path d="M20 20l-3.5-3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
        <div class="search-results" id="search-results" role="listbox" aria-label="Résultats de recherche" hidden></div>
      </form>

      <!-- Téléphone + accroche -->
      <a href="tel:0278775393" class="header-phone" aria-label="Appelez-nous au 02 78 77 53 93 — conseil et prise de commande">
        <span class="header-phone-ico" aria-hidden="true">
          <svg width="19" height="19" viewBox="0 0 24 24" fill="none">
            <path d="M6.6 3.5c.6 0 1.13.4 1.3.98l.86 2.96a1.4 1.4 0 0 1-.36 1.4L7.06 10.1a13 13 0 0 0 5.4 5.4l1.26-1.34a1.4 1.4 0 0 1 1.4-.36l2.96.86c.58.17.98.7.98 1.3v2.8c0 .82-.7 1.47-1.52 1.38C9.9 19.96 3.54 13.6 2.84 5.42 2.77 4.6 3.42 3.9 4.24 3.9L6.6 3.5Z" fill="currentColor"/>
          </svg>
        </span>
        <span class="header-phone-txt">
          <span class="header-phone-hook">Un conseil ou une commande ?</span>
          <span class="header-phone-num">02 78 77 53 93</span>
        </span>
      </a>

      <!-- Panier (drawer) -->
      <button
        class="cart"
        type="button"
        data-cart-toggle
        aria-label="Ouvrir le panier"
        aria-haspopup="dialog"
        aria-expanded="false"
        aria-controls="cart-drawer"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M3 4h2l2.4 12.3a1 1 0 0 0 1 .8h9.2a1 1 0 0 0 1-.8L21 8H6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="10" cy="20" r="1.4" fill="currentColor"/>
          <circle cx="18" cy="20" r="1.4" fill="currentColor"/>
        </svg>
        <span class="cart-badge" data-cart-count aria-hidden="true">0</span>
        <span class="cart-total" data-cart-total>0,00&nbsp;€</span>
      </button>

    </div>
  </div>

  <!-- ═══ Ligne 2 : rubriques (mega-menu) ═══ -->
  <div class="header-nav">
    <nav class="nav-links" aria-label="Navigation principale">
      {silos.map(silo => {
        const isCurrent = silo.slug === currentSiloSlug
        const showMega = showAllMegaMenus || isCurrent
        const panelId = `mega-${silo.slug}`
        const customMega = getCustomMega(silo.slug)

        if (!showMega) {
          return (
            <a href={silo.href} class="nav-link">{silo.label}</a>
          )
        }

        return (
          <div class:list={['nav-item', 'nav-item--mega', { 'nav-item--mega-wide': !!customMega }]} data-mega-item data-mega-wide={customMega ? 'true' : undefined}>
            <button
              type="button"
              class:list={['nav-link', 'nav-trigger', { 'is-active': isCurrent }]}
              aria-haspopup="true"
              aria-expanded="false"
              aria-controls={panelId}
            >
              {silo.label}
              <svg class="caret" width="10" height="10" viewBox="0 0 12 12" aria-hidden="true">
                <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>

            <div
              class:list={['mega-panel', { 'mega-panel--custom': !!customMega }]}
              id={panelId}
              role="menu"
              aria-hidden="true"
            >
              {customMega ? (
                <>
                  <a href={silo.href} class:list={['mega-pillar', 'mega-pillar--cta', { active: currentPath === silo.href }]} role="menuitem">
                    {customMega.pillarCta ?? `Voir tout : ${silo.label}`} <span aria-hidden="true">→</span>
                  </a>
                  <div class:list={['mega-custom-grid', {
                    'mega-custom-grid--auto':   customMega.layout === 'auto',
                    'mega-custom-grid--3x2':    customMega.layout === 'grid-3x2',
                  }]}>
                    {customMega.columns.map(col => (
                      <div class:list={['mega-ccol', { 'mega-ccol--no-img': !col.image }]}>
                        <a
                          href={col.href}
                          role="menuitem"
                          class:list={['mega-ccol-title', { active: currentPath === col.href }]}
                        >
                          {col.title}
                          <span class="mega-ccol-arrow" aria-hidden="true">→</span>
                        </a>
                        {col.image ? (
                          <a href={col.href} class="mega-ccol-img" tabindex="-1" aria-hidden="true">
                            <img src={col.image} alt={col.imageAlt ?? ''} loading="lazy" />
                          </a>
                        ) : null}
                        <div class="mega-ccol-list">
                          {col.items.map(it => (
                            <a
                              href={it.href}
                              role="menuitem"
                              class:list={['mega-ccol-link', { active: currentPath === it.href }]}
                            >
                              {it.label}
                            </a>
                          ))}
                        </div>
                      </div>
                    ))}
                    {customMega.promo ? (
                      <a href={customMega.promo.href} class="mega-promo" role="menuitem">
                        {customMega.promo.eyebrow ? <span class="mega-promo-eyebrow">{customMega.promo.eyebrow}</span> : null}
                        <span class="mega-promo-title">{customMega.promo.title}</span>
                        {customMega.promo.image ? (
                          <span class="mega-promo-img"><img src={customMega.promo.image} alt={customMega.promo.imageAlt ?? ''} loading="lazy" /></span>
                        ) : null}
                        {customMega.promo.text ? <span class="mega-promo-text">{customMega.promo.text}</span> : null}
                        <span class="mega-promo-cta">{customMega.promo.ctaLabel} <span aria-hidden="true">→</span></span>
                      </a>
                    ) : null}
                  </div>
                </>
              ) : (
                <>
                  <a href={silo.href} class:list={['mega-pillar', { active: currentPath === silo.href }]} role="menuitem">
                    Voir tout : {silo.label} <span aria-hidden="true">→</span>
                  </a>
                  <div class="mega-grid">
                    {silo.children?.map(cat => (
                      <div class="mega-col">
                        <a
                          href={cat.href}
                          role="menuitem"
                          class:list={['mega-cat', { active: currentPath === cat.href, 'has-sub': !!cat.children?.length }]}
                        >
                          {cat.label}
                        </a>
                        {cat.children?.length ? (
                          <div class="mega-sublist">
                            {cat.children.map(sub => (
                              <a
                                href={sub.href}
                                role="menuitem"
                                class:list={['mega-sublink', { active: currentPath === sub.href }]}
                              >
                                {sub.label}
                              </a>
                            ))}
                          </div>
                        ) : null}
                      </div>
                    ))}
                  </div>
                </>
              )}
            </div>
          </div>
        )
      })}
    </nav>
  </div>

  <!-- ═══ Menu mobile ═══ -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <nav aria-label="Navigation mobile">

      <!-- Recherche mobile (même index, résultats en ligne) -->
      <form class="mobile-search" role="search" aria-label="Recherche sur le site" onsubmit="return false;">
        <input
          type="search"
          id="mobile-site-search"
          placeholder="Trouver un produit"
          aria-label="Trouver un produit"
          autocomplete="off"
          role="combobox"
          aria-expanded="false"
          aria-controls="mobile-search-results"
          aria-autocomplete="list"
        />
      </form>
      <div class="mobile-search-results" id="mobile-search-results" role="listbox" aria-label="Résultats de recherche" hidden></div>

      <!-- Panier mobile (ouvre le drawer panier, identique au bouton desktop) -->
      <button
        class="mobile-cart"
        type="button"
        data-cart-toggle
        aria-label="Ouvrir le panier"
        aria-haspopup="dialog"
        aria-expanded="false"
        aria-controls="cart-drawer"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M3 4h2l2.4 12.3a1 1 0 0 0 1 .8h9.2a1 1 0 0 0 1-.8L21 8H6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="10" cy="20" r="1.4" fill="currentColor"/>
          <circle cx="18" cy="20" r="1.4" fill="currentColor"/>
        </svg>
        <span class="mobile-cart-label">Mon panier</span>
        <span class="mobile-cart-meta">
          <span class="mobile-cart-badge" data-cart-count>0</span>
          <span class="mobile-cart-total" data-cart-total>0,00&nbsp;€</span>
        </span>
      </button>

      {silos.map(silo => {
        const isCurrent = silo.slug === currentSiloSlug
        const showMega = showAllMegaMenus || isCurrent
        const customMega = getCustomMega(silo.slug)

        if (!showMega) {
          return <a href={silo.href} class="mobile-link">{silo.label}</a>
        }

        return (
          <details class:list={['mobile-group', { 'is-current': isCurrent }]} open={isCurrent}>
            <summary class="mobile-summary">
              <span>{silo.label}</span>
              <svg class="mobile-caret" width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
                <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </summary>
            <div class="mobile-children">
              <a
                href={silo.href}
                class:list={['mobile-link', 'mobile-pillar-link', { active: currentPath === silo.href }]}
              >
                {customMega?.pillarCta ?? `Voir tout : ${silo.label}`} <span aria-hidden="true">→</span>
              </a>

              {customMega ? (
                <>
                  {customMega.columns.map(col => (
                    <details class="mobile-subgroup">
                      <summary class="mobile-subsummary">
                        <span>{col.title}</span>
                        <svg class="mobile-caret" width="11" height="11" viewBox="0 0 12 12" aria-hidden="true">
                          <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </summary>
                      <div class="mobile-subchildren">
                        <a
                          href={col.href}
                          class:list={['mobile-link', 'mobile-cat-link', { active: currentPath === col.href }]}
                        >
                          Voir tout : {col.title} <span aria-hidden="true">→</span>
                        </a>
                        {col.items.map(it => (
                          <a
                            href={it.href}
                            class:list={['mobile-link', 'mobile-child', { active: currentPath === it.href }]}
                          >
                            {it.label}
                          </a>
                        ))}
                      </div>
                    </details>
                  ))}
                  {customMega.promo ? (
                    <a href={customMega.promo.href} class="mobile-link mobile-promo-link">
                      {customMega.promo.eyebrow ? <span class="mobile-promo-eyebrow">{customMega.promo.eyebrow}</span> : null}
                      <span>{customMega.promo.title} <span aria-hidden="true">→</span></span>
                    </a>
                  ) : null}
                </>
              ) : (
                silo.children?.map(cat => (
                  cat.children?.length ? (
                    <details class="mobile-subgroup">
                      <summary class="mobile-subsummary">
                        <span>{cat.label}</span>
                        <svg class="mobile-caret" width="11" height="11" viewBox="0 0 12 12" aria-hidden="true">
                          <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </summary>
                      <div class="mobile-subchildren">
                        <a
                          href={cat.href}
                          class:list={['mobile-link', 'mobile-cat-link', { active: currentPath === cat.href }]}
                        >
                          Voir tout : {cat.label} <span aria-hidden="true">→</span>
                        </a>
                        {cat.children.map(sub => (
                          <a
                            href={sub.href}
                            class:list={['mobile-link', 'mobile-child', { active: currentPath === sub.href }]}
                          >
                            {sub.label}
                          </a>
                        ))}
                      </div>
                    </details>
                  ) : (
                    <a
                      href={cat.href}
                      class:list={['mobile-link', 'mobile-child', { active: currentPath === cat.href }]}
                    >
                      {cat.label}
                    </a>
                  )
                ))
              )}
            </div>
          </details>
        )
      })}

      <!-- Liens utilitaires (mobile) -->
      <div class="mobile-utils">
        <a href="/realisations-plv/" class="mobile-link">Réalisations</a>
        <a href="/actualites-plv/" class="mobile-link">Blog</a>
        <a href="/contact/" class="mobile-link">Contact</a>
        <a href="tel:0278775393" class="mobile-link">02 78 77 53 93</a>
      </div>

      <a href="/devis/" class="mobile-cta">Devis gratuit →</a>
    </nav>
  </div>

  <!-- ═══ Drawer panier ═══ -->
  <div class="cart-overlay" data-cart-overlay hidden></div>
  <aside
    class="cart-drawer"
    id="cart-drawer"
    role="dialog"
    aria-modal="true"
    aria-label="Votre panier"
    aria-hidden="true"
  >
    <div class="cd-head">
      <h2 class="cd-title">Votre panier</h2>
      <button type="button" class="cd-close" data-cart-close aria-label="Fermer le panier">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <p class="cd-empty" data-cart-empty>Votre panier est vide.</p>

    <div class="cd-lines" data-cart-lines></div>

    <div class="cd-foot" data-cart-foot hidden>
      <div class="cd-total-row">
        <span>Total</span>
        <span class="cd-total" data-cart-total-text>0,00 €</span>
      </div>
      <p class="cd-note">Livraison &amp; remises calculées à l'étape de paiement sécurisé.</p>
      <button type="button" class="cd-checkout" data-cart-checkout>Passer commande</button>
      <button type="button" class="cd-clear" data-cart-clear>Vider le panier</button>
      <p class="cd-error" data-cart-error hidden></p>
    </div>
  </aside>
</header>

<script>
import { cart } from '../scripts/cart'

// ── Mega-menu : hover + clic + clavier ──────────────────────────────────────
const items = document.querySelectorAll<HTMLElement>('[data-mega-item]')

for (const item of Array.from(items)) {
  const trigger = item.querySelector<HTMLButtonElement>('.nav-trigger')
  const panel   = item.querySelector<HTMLElement>('.mega-panel')
  if (!trigger || !panel) continue

  let closeTimer: number | undefined

  const adjustAlignment = () => {
    const isWide = item.dataset.megaWide === 'true'

    if (isWide) {
      // Mega large : aligne le panneau sur la largeur du conteneur .nav-links
      // (donc sur toute la largeur du header limitée par --header-max-w).
      const navLinks = item.closest<HTMLElement>('.nav-links')
      if (!navLinks) return
      const navRect  = navLinks.getBoundingClientRect()
      const itemRect = item.getBoundingClientRect()
      panel.style.width = `${Math.round(navRect.width)}px`
      panel.style.left  = `${Math.round(navRect.left - itemRect.left)}px`
      return
    }

    // Clamp dans le viewport : le panneau s'ancre sous le trigger (left:0
    // relatif à l'item) puis est décalé juste ce qu'il faut pour rester
    // entre les deux marges, sans jamais déborder à gauche NI à droite.
    const margin = 16
    panel.style.left = '0px'
    const itemLeft   = item.getBoundingClientRect().left
    const panelWidth = panel.offsetWidth
    const maxLeft    = window.innerWidth - margin - panelWidth
    // Position viewport souhaitée = sous l'item ; bornée à [margin, maxLeft].
    const clampedLeft = Math.max(margin, Math.min(itemLeft, maxLeft))
    panel.style.left = `${Math.round(clampedLeft - itemLeft)}px`
  }

  const open = () => {
    window.clearTimeout(closeTimer)
    trigger.setAttribute('aria-expanded', 'true')
    panel.setAttribute('aria-hidden', 'false')
    item.classList.add('is-open')
    requestAnimationFrame(adjustAlignment)
  }

  const close = () => {
    trigger.setAttribute('aria-expanded', 'false')
    panel.setAttribute('aria-hidden', 'true')
    item.classList.remove('is-open')
  }

  const scheduleClose = () => {
    window.clearTimeout(closeTimer)
    closeTimer = window.setTimeout(close, 150)
  }

  // Hover (desktop)
  item.addEventListener('mouseenter', open)
  item.addEventListener('mouseleave', scheduleClose)

  // Clic — toggle, et empêche la fermeture immédiate par mouseleave
  trigger.addEventListener('click', (ev) => {
    ev.preventDefault()
    const isOpen = trigger.getAttribute('aria-expanded') === 'true'
    if (isOpen) close()
    else open()
  })

  // Clavier — Enter / Space ouvrent et focusent le 1er lien ; Escape ferme
  trigger.addEventListener('keydown', (ev) => {
    if (ev.key === 'Enter' || ev.key === ' ') {
      ev.preventDefault()
      open()
      panel.querySelector<HTMLAnchorElement>('a')?.focus()
    } else if (ev.key === 'Escape') {
      close()
    } else if (ev.key === 'ArrowDown') {
      ev.preventDefault()
      open()
      panel.querySelector<HTMLAnchorElement>('a')?.focus()
    }
  })

  panel.addEventListener('keydown', (ev) => {
    if (ev.key === 'Escape') {
      close()
      trigger.focus()
    }
  })

  // Clic en dehors → ferme
  document.addEventListener('click', (ev) => {
    if (!item.contains(ev.target as Node)) close()
  })
}

// ── Hamburger (mobile) ──────────────────────────────────────────────────────
const hamburger  = document.getElementById('hamburger')
const mobileMenu = document.getElementById('mobile-menu')

if (hamburger && mobileMenu) {
  hamburger.addEventListener('click', () => {
    const isOpen = hamburger.getAttribute('aria-expanded') === 'true'
    hamburger.setAttribute('aria-expanded', String(!isOpen))
    mobileMenu.setAttribute('aria-hidden', String(isOpen))
    hamburger.classList.toggle('is-open', !isOpen)
    mobileMenu.classList.toggle('is-open', !isOpen)
  })
}

// ── Recherche : index statique + matcher client ─────────────────────────────
type SearchEntry = { t: string; u: string; k: string; d: string; s: string }

let searchIndex: SearchEntry[] | null = null
let indexPromise: Promise<SearchEntry[]> | null = null

const normalizeQuery = (str: string): string =>
  str.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase().replace(/[^a-z0-9]+/g, ' ').trim()

function loadSearchIndex(): Promise<SearchEntry[]> {
  if (searchIndex) return Promise.resolve(searchIndex)
  if (!indexPromise) {
    indexPromise = fetch('/search-index.json')
      .then((r) => (r.ok ? r.json() : []))
      .then((d: SearchEntry[]) => (searchIndex = Array.isArray(d) ? d : []))
      .catch(() => (searchIndex = []))
  }
  return indexPromise
}

function runSearch(query: string, idx: SearchEntry[], limit = 8): SearchEntry[] {
  const q = normalizeQuery(query)
  if (!q) return []
  const tokens = q.split(' ').filter(Boolean)
  const scored: { e: SearchEntry; score: number }[] = []
  for (const e of idx) {
    const title = normalizeQuery(e.t)
    let score = 0
    let ok = true
    for (const tk of tokens) {
      if (!e.s.includes(tk)) { ok = false; break }
      if (title.startsWith(tk)) score += 6
      else if (title.includes(tk)) score += 4
      else score += 1
    }
    if (!ok) continue
    if (title === q) score += 12
    else if (title.startsWith(q)) score += 6
    scored.push({ e, score })
  }
  scored.sort((a, b) => b.score - a.score)
  return scored.slice(0, limit).map((x) => x.e)
}

const escapeHtml = (s: string): string =>
  s.replace(/[&<>"']/g, (c) =>
    ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string),
  )

function initSearch(input: HTMLInputElement | null, results: HTMLElement | null) {
  if (!input || !results) return
  let activeIdx = -1
  let currentItems: SearchEntry[] = []
  let timer: number | undefined

  const closeResults = () => {
    results.hidden = true
    results.innerHTML = ''
    input.setAttribute('aria-expanded', 'false')
    input.removeAttribute('aria-activedescendant')
    activeIdx = -1
    currentItems = []
  }

  const renderResults = (items: SearchEntry[]) => {
    currentItems = items
    activeIdx = -1
    if (!input.value.trim()) { closeResults(); return }
    results.innerHTML = items.length
      ? items
          .map(
            (e, i) =>
              `<a class="sr-item" role="option" id="${results.id}-opt-${i}" href="${escapeHtml(e.u)}" tabindex="-1">` +
              `<span class="sr-text">` +
              `<span class="sr-title">${escapeHtml(e.t)}</span>` +
              `<span class="sr-kind">${escapeHtml(e.k)}</span>` +
              `</span>` +
              `</a>`,
          )
          .join('')
      : '<p class="sr-empty">Aucun résultat pour cette recherche</p>'
    results.hidden = false
    input.setAttribute('aria-expanded', 'true')
  }

  const optionEls = (): HTMLElement[] =>
    Array.from(results.querySelectorAll<HTMLElement>('.sr-item'))

  const setActive = (idx: number) => {
    const els = optionEls()
    if (!els.length) return
    els.forEach((el) => el.classList.remove('is-active'))
    activeIdx = (idx + els.length) % els.length
    const el = els[activeIdx]
    el.classList.add('is-active')
    el.scrollIntoView({ block: 'nearest' })
    input.setAttribute('aria-activedescendant', el.id)
  }

  const doSearch = async () => {
    const idx = await loadSearchIndex()
    renderResults(runSearch(input.value, idx))
  }

  input.addEventListener('input', () => {
    window.clearTimeout(timer)
    if (!input.value.trim()) { closeResults(); return }
    void loadSearchIndex()
    timer = window.setTimeout(doSearch, 130)
  })

  input.addEventListener('focus', () => {
    void loadSearchIndex()
    if (input.value.trim() && currentItems.length) results.hidden = false
  })

  input.addEventListener('keydown', (ev: KeyboardEvent) => {
    const els = optionEls()
    if (ev.key === 'ArrowDown') {
      ev.preventDefault()
      if (els.length) setActive(activeIdx + 1)
    } else if (ev.key === 'ArrowUp') {
      ev.preventDefault()
      if (els.length) setActive(activeIdx - 1)
    } else if (ev.key === 'Enter') {
      const target = els[activeIdx] ?? els[0]
      if (target) {
        ev.preventDefault()
        window.location.href = target.getAttribute('href') as string
      }
    } else if (ev.key === 'Escape') {
      closeResults()
      input.blur()
    }
  })

  document.addEventListener('click', (ev) => {
    const node = ev.target as Node
    if (node !== input && !results.contains(node)) closeResults()
  })
}

initSearch(
  document.getElementById('site-search') as HTMLInputElement | null,
  document.getElementById('search-results'),
)
