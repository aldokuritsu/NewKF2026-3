---
import BaseLayout from '../layouts/BaseLayout.astro'
import DevisForm from '../components/DevisForm.astro'
---

<BaseLayout
  title="Demander un devis PLV gratuit | KONTFEEL"
  description="Formulaire de demande de devis pour vos projets PLV sur mesure. Réponse personnalisée sous 48h ouvrées par notre équipe."
  hideDevisModal
>
  <main class="devis-page">
    <header class="devis-hero">
      <p class="devis-eyebrow">Devis personnalisé · réponse sous 48h</p>
      <h1>Parlons de votre projet PLV</h1>
      <p class="devis-lead">
        Décrivez votre besoin en quelques lignes et joignez vos visuels.
        Notre équipe analyse votre brief, évalue les volumes et vous revient
        sous <strong>48h ouvrées</strong> avec une proposition chiffrée.
      </p>
    </header>

    <DevisForm variant="page" />
  </main>
</BaseLayout>

<style>
  .devis-page { max-width: 760px; margin: 0 auto; padding: 56px 24px 80px; }
  @media (max-width: 640px) { .devis-page { padding: 32px 16px 60px; } }

  .devis-hero { text-align: center; margin-bottom: 40px; }
  .devis-eyebrow {
    display: inline-block; font-size: 12px; font-weight: 600;
    text-transform: uppercase; letter-spacing: .12em;
    color: var(--rose, #E8336D); margin: 0 0 12px;
  }
  .devis-hero h1 {
    font-size: clamp(28px, 4vw, 38px); font-weight: 700;
    color: var(--dark, #1a1a2e); margin: 0 0 12px; line-height: 1.2;
  }
  .devis-lead {
    color: var(--gray-700, #374151); font-size: 16px; line-height: 1.6;
    margin: 0 auto; max-width: 580px;
  }
</style>
