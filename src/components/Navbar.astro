// ── Panier : drawer + badge ─────────────────────────────────────────────────
;(function initCart() {
  const drawer  = document.getElementById('cart-drawer')
  const overlay = document.querySelector<HTMLElement>('[data-cart-overlay]')
  const toggles = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-cart-toggle]'))
  if (!drawer || !overlay || !toggles.length) return

  const linesEl = drawer.querySelector<HTMLElement>('[data-cart-lines]')!
  const emptyEl = drawer.querySelector<HTMLElement>('[data-cart-empty]')!
  const footEl  = drawer.querySelector<HTMLElement>('[data-cart-foot]')!
  const errEl   = drawer.querySelector<HTMLElement>('[data-cart-error]')!
  const countEls = Array.from(document.querySelectorAll<HTMLElement>('[data-cart-count]'))
  const totalEls = Array.from(document.querySelectorAll<HTMLElement>('[data-cart-total]'))
  const totalTextEl = drawer.querySelector<HTMLElement>('[data-cart-total-text]')!

  const esc = (s: string) =>
    String(s).replace(/[&<>"']/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string),
    )
  const fmt = (n: number, cur: string) =>
    new Intl.NumberFormat('fr-FR', { style: 'currency', currency: (cur || 'eur').toUpperCase() }).format(n)

  function renderBadge() {
    const c = cart.count()
    countEls.forEach((el) => (el.textContent = String(c)))
    totalEls.forEach((el) => (el.textContent = fmt(cart.total(), cart.currency())))
  }

  function renderDrawer() {
    const lines = cart.all()
    const empty = lines.length === 0
    emptyEl.hidden = !empty
    footEl.hidden = empty
    linesEl.innerHTML = empty
      ? ''
      : lines
          .map((l) => {
            const sub = [l.variantLabel, ...(l.optionLabels ?? [])].filter(Boolean).join(' · ')
            return (
              `<div class="cd-line" data-line="${esc(l.id)}">` +
              (l.image ? `<img class="cd-thumb" src="${esc(l.image)}" alt="" loading="lazy" />` : `<div class="cd-thumb"></div>`) +
              `<div class="cd-info">` +
              `<p class="cd-name">${esc(l.name)}</p>` +
              (sub ? `<p class="cd-sub">${esc(sub)}</p>` : '') +
              `<div class="cd-qty">` +
              `<button type="button" class="cd-step" data-dec aria-label="Diminuer">−</button>` +
              `<span class="cd-qval">${l.qty}</span>` +
              `<button type="button" class="cd-step" data-inc aria-label="Augmenter">+</button>` +
              `<button type="button" class="cd-rm" data-rm>Retirer</button>` +
              `</div></div>` +
              `<span class="cd-price">${esc(fmt(l.unitPrice * l.qty, l.currency))}</span>` +
              `</div>`
            )
          })
          .join('')
    totalTextEl.textContent = fmt(cart.total(), cart.currency())
  }

  function refresh() {
    renderBadge()
    if (drawer!.classList.contains('is-open')) renderDrawer()
  }

  function open() {
    renderDrawer()
    drawer!.classList.add('is-open')
    overlay!.hidden = false
    requestAnimationFrame(() => overlay!.classList.add('is-open'))
    drawer!.setAttribute('aria-hidden', 'false')
    toggles.forEach((t) => t.setAttribute('aria-expanded', 'true'))
    document.body.style.overflow = 'hidden'
    // Si le menu mobile est ouvert, on le ferme (le panier prend la main).
    const ham = document.getElementById('hamburger')
    const mm  = document.getElementById('mobile-menu')
    if (ham?.getAttribute('aria-expanded') === 'true' && mm) {
      ham.setAttribute('aria-expanded', 'false')
      mm.setAttribute('aria-hidden', 'true')
      ham.classList.remove('is-open')
      mm.classList.remove('is-open')
    }
  }
  function close() {
    drawer!.classList.remove('is-open')
    overlay!.classList.remove('is-open')
    drawer!.setAttribute('aria-hidden', 'true')
    toggles.forEach((t) => t.setAttribute('aria-expanded', 'false'))
    document.body.style.overflow = ''
    setTimeout(() => { if (!drawer!.classList.contains('is-open')) overlay!.hidden = true }, 250)
  }

  toggles.forEach((t) => t.addEventListener('click', open))
  overlay.addEventListener('click', close)
  drawer.querySelector('[data-cart-close]')?.addEventListener('click', close)
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer.classList.contains('is-open')) close()
  })

  linesEl.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('button')
    if (!btn) return
    const row = btn.closest<HTMLElement>('[data-line]')
    if (!row) return
    const id = row.getAttribute('data-line')!
    const line = cart.all().find((l) => l.id === id)
    if (!line) return
    if (btn.hasAttribute('data-rm')) cart.remove(id)
    else if (btn.hasAttribute('data-inc')) cart.setQty(id, line.qty + 1)
    else if (btn.hasAttribute('data-dec')) {
      if (line.qty <= 1) cart.remove(id)
      else cart.setQty(id, line.qty - 1)
    }
  })

  drawer.querySelector('[data-cart-clear]')?.addEventListener('click', () => cart.clear())

  const checkoutBtn = drawer.querySelector<HTMLButtonElement>('[data-cart-checkout]')!
  checkoutBtn.addEventListener('click', async () => {
    const items = cart.checkoutItems()
    if (!items.length) return
    errEl.hidden = true
    const label = checkoutBtn.textContent
    checkoutBtn.disabled = true
    checkoutBtn.textContent = 'Redirection…'
    try {
      const res = await fetch('/api/checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items }),
      })
      const result = await res.json()
      if (!res.ok || !result.url) throw new Error(result.error || 'Erreur Stripe')
      window.location.href = result.url
    } catch (err: any) {
      errEl.textContent = err?.message || 'Une erreur est survenue.'
      errEl.hidden = false
      checkoutBtn.disabled = false
      checkoutBtn.textContent = label
    }
  })

  cart.onChange(refresh)
  cart.onOpenRequest(open)
  renderBadge()
})()
</script>

