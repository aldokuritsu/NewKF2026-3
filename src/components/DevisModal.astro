---
/**
 * DevisModal — Wrapper modal autour de DevisForm.
 *
 * Ouverture : tout élément avec href="#devis" ou data-open-devis
 * (ex : <a href="#devis">, <button data-open-devis>)
 *
 * Le formulaire interne est DevisForm — réutilisé sur la page /devis/.
 * Reset complet à chaque ouverture via window.__resetDevisForm().
 *
 * Props :
 *   productRef? : string — référence produit transmise au formulaire
 *                          (cf. ChildLayout qui passe pageLabel)
 */
import DevisForm from './DevisForm.astro'

interface Props {
  productRef?: string
}

const { productRef } = Astro.props
---

<dialog
  id="devis-modal"
  class="devis-modal"
  aria-label="Demande de devis"
  aria-modal="true"
>
  <div class="devis-modal__inner">
    <button class="devis-modal__close" aria-label="Fermer la fenêtre" data-close-devis>
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M1 1l16 16M17 1L1 17" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
      </svg>
    </button>

    <header class="devis-modal__header">
      <h2 class="devis-modal__title">Demande de devis</h2>
      <p class="devis-modal__subtitle">Réponse personnalisée sous <strong>48h ouvrées</strong>.</p>
    </header>

    <DevisForm productRef={productRef} variant="modal" />
  </div>
</dialog>

<style>
  .devis-modal {
    position: fixed;
    inset: 0;
    margin: auto;
    width: min(720px, calc(100vw - 32px));
    max-height: calc(100dvh - 32px);
    overflow-y: auto;
    border: none;
    border-radius: 16px;
    padding: 0;
    background: #fff;
    box-shadow: 0 24px 80px rgba(0, 0, 0, .22);
  }
  .devis-modal::backdrop {
    background: rgba(15, 20, 30, .55);
    backdrop-filter: blur(3px);
  }
  .devis-modal[open] { animation: devis-in .22s ease-out; }
  @keyframes devis-in {
    from { opacity: 0; transform: translateY(12px) scale(.97); }
    to   { opacity: 1; transform: none; }
  }

  .devis-modal__inner {
    position: relative;
    padding: 32px 32px 32px;
  }
  @media (max-width: 600px) {
    .devis-modal__inner { padding: 24px 16px 24px; }
  }

  .devis-modal__close {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--gray-100, #f5f5f5);
    border: none;
    border-radius: 50%;
    color: var(--dark, #1a1a2e);
    cursor: pointer;
    transition: background .15s;
    z-index: 2;
  }
  .devis-modal__close:hover { background: var(--gray-200, #e8e8e8); }

  .devis-modal__header { margin: 0 0 24px; padding-right: 40px; }
  .devis-modal__title {
    font-size: 22px; font-weight: 700;
    color: var(--dark, #1a1a2e); margin: 0 0 4px;
  }
  .devis-modal__subtitle {
    font-size: 14px; color: var(--gray-500, #6b7280); margin: 0;
  }
</style>

<script>
  // @ts-nocheck
  const modal = document.getElementById('devis-modal') as HTMLDialogElement | null

  if (modal) {
    // Ouverture via [href="#devis"] / [data-open-devis]
    document.addEventListener('click', (e) => {
      const trigger = (e.target as Element)?.closest?.(
        'a[href="#devis"], button[data-open-devis], [data-open-devis]'
      )
      if (!trigger) return
      e.preventDefault()
      // Reset complet à chaque ouverture (state, fichiers, success…)
      ;(window as any).__resetDevisForm?.()
      modal.showModal()
    })

    // Fermeture : backdrop click, bouton close, touche Escape (native sur <dialog>)
    modal.addEventListener('click', (e) => {
      if (e.target === modal) modal.close()
      if ((e.target as Element)?.closest?.('[data-close-devis]')) modal.close()
    })
  }
</script>
