---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allPosts = await getCollection('posts', p => !!p.data.date);
const posts = allPosts.sort((a, b) =>
  new Date(b.data.date!).getTime() - new Date(a.data.date!).getTime()
);
---

<BaseLayout
  title="Actualités PLV — Conseils et tendances merchandising | KONTFEEL"
  description="Conseils d'experts sur la PLV, le merchandising et la communication en point de vente. Fabricant français depuis 10 ans."
>
  <section class="blog-list">
    <div class="blog-container">

      <header class="blog-header">
        <h1 class="blog-title">Actualités PLV</h1>
        <p class="blog-intro">Conseils terrain, choix techniques et tendances merchandising par les équipes Kontfeel.</p>
      </header>

      {posts.length === 0 ? (
        <p class="blog-empty">Articles à venir.</p>
      ) : (
        <ul class="blog-grid">
          {posts.map(post => {
            const date = new Date(post.data.date!).toLocaleDateString('fr-FR', {
              year: 'numeric', month: 'long', day: 'numeric'
            });
            return (
              <li class="blog-card">
                {post.data.image && (
                  <a href={`/actualites-plv/${post.id}/`}>
                    <img
                      src={post.data.image}
                      alt={post.data.imageAlt ?? post.data.title}
                      class="blog-card-img"
                      loading="lazy"
                    />
                  </a>
                )}
                <div class="blog-card-body">
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="blog-card-tags">
                      {post.data.tags.slice(0, 2).map(tag => (
                        <span class="blog-card-tag">{tag}</span>
                      ))}
                    </div>
                  )}
                  <h2 class="blog-card-title">
                    <a href={`/actualites-plv/${post.id}/`}>{post.data.title}</a>
                  </h2>
                  {post.data.description && (
                    <p class="blog-card-desc">{post.data.description}</p>
                  )}
                  <div class="blog-card-meta">
                    <time datetime={post.data.date}>{date}</time>
                    <span>·</span>
                    <span>{post.data.author}</span>
                  </div>
                </div>
              </li>
            );
          })}
        </ul>
      )}

    </div>
  </section>
</BaseLayout>

<style>
  .blog-list {
    padding: 64px 0 96px;
  }
  .blog-container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 24px;
  }
  .blog-header {
    margin-bottom: 48px;
  }
  .blog-title {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 700;
    color: var(--dark);
    margin-bottom: 12px;
  }
  .blog-intro {
    font-size: 17px;
    color: var(--gray-600);
    line-height: 1.6;
  }
  .blog-empty {
    color: var(--gray-500);
    font-size: 16px;
  }
  .blog-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 32px;
  }
  .blog-card {
    background: white;
    border: 1px solid var(--gray-100);
    border-radius: var(--radius);
    overflow: hidden;
    transition: box-shadow 0.2s;
  }
  .blog-card:hover { box-shadow: 0 4px 24px rgba(0,0,0,0.08); }
  .blog-card-img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
  }
  .blog-card-body {
    padding: 20px 24px 24px;
  }
  .blog-card-tags {
    display: flex;
    gap: 6px;
    margin-bottom: 10px;
  }
  .blog-card-tag {
    font-size: 11px;
    font-weight: 600;
    color: var(--rose);
    background: var(--rose-light);
    padding: 3px 8px;
    border-radius: 99px;
  }
  .blog-card-title {
    font-size: 17px;
    font-weight: 700;
    line-height: 1.35;
    margin-bottom: 10px;
  }
  .blog-card-title a {
    color: var(--dark);
    text-decoration: none;
  }
  .blog-card-title a:hover { color: var(--rose); }
  .blog-card-desc {
    font-size: 14px;
    line-height: 1.6;
    color: var(--gray-600);
    margin-bottom: 16px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: var(--gray-500);
  }
</style>
