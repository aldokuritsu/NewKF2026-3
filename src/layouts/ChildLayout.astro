---
/**
 * ChildLayout — Layout des pages catégorie / sous-catégorie
 * (ex : /plv-carton/totems/ ou /plv-carton/totems/elliptiques/)
 *
 * Props :
 *   seoTitle       : string
 *   seoDescription : string
 *   siloSlug       : string     — slug de la rubrique de 1er niveau (active le mega-menu)
 *   pageLabel      : string     — libellé de la page courante (pré-remplit le devis)
 *   crumbs         : Crumb[]    — fil d'Ariane complet (Accueil › … › page courante)
 *   currentPath    : string     — URL courante pour l'état actif (sub-nav + mega-menu)
 *   ogImage?       : string
 */
import BaseLayout    from './BaseLayout.astro'
import Breadcrumb    from '../components/Breadcrumb.astro'
import BlockRenderer from '../components/blocks/BlockRenderer.astro'
import SubNav        from '../components/SubNav.astro'
import { buildSubNav } from '../lib/blockNav'

interface Crumb {
  label: string
  href?: string
}

interface Props {
  seoTitle:       string
  seoDescription: string
  siloSlug:       string
  pageLabel:      string
  crumbs:         Crumb[]
  currentPath:    string
  ogImage?:       string
  blocks:         any[]
}

const {
  seoTitle, seoDescription,
  siloSlug, pageLabel, crumbs,
  currentPath, ogImage, blocks
} = Astro.props

const subNavEntries = buildSubNav(blocks)
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  siloSlug={siloSlug}
  currentPath={currentPath}
  ogImage={ogImage}
  productRef={pageLabel}
>
  <!-- Sub-nav (raccourcis d'ancres dans la page) -->
  <SubNav entries={subNavEntries} />

  <!-- Breadcrumb : Accueil › Rubrique › … › Page courante -->
  <Breadcrumb crumbs={crumbs} />

  <!-- Blocs de contenu -->
  <BlockRenderer blocks={blocks} />

  <slot />
</BaseLayout>
