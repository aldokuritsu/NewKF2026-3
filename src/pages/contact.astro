>
  <section style="max-width:var(--max-w);margin:0 auto;padding:64px 24px;">
    <h1 style="font-size:32px;font-weight:700;color:var(--dark);margin-bottom:16px;">Contactez-nous</h1>
    <p style="font-size:16px;color:var(--gray-700);line-height:1.7;">Page de contact à venir. En attendant, vous pouvez nous joindre au 02 78 77 53 93 ou à contact@kontfeel.fr.</p>
  </section>
</BaseLayout>
